<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.taskmag.server.dataoperation.mapper.DynamicQueryMapper">

    <select id="selectPage" resultType="java.util.LinkedHashMap">
        SELECT ${selectColumns}
        FROM ${tableName}
        WHERE ${whereClause}
        LIMIT #{offset}, #{pageSize}
    </select>

    <select id="count" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM ${tableName}
        WHERE ${whereClause}
    </select>
</mapper>
